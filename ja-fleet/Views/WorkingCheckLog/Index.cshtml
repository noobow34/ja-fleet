@model jafleet.Models.WorkingCheckLogModel
@{
    Layout = "_LayoutNoHead";
    Model.Title = $"稼働チェックログ {Model.SearchDate:yyyy/MM/dd}";
    var prevDate = Model.SearchDate.AddDays(-1).ToString("yyyyMMdd");
    var nextDate = Model.SearchDate.AddDays(1).ToString("yyyyMMdd");
    var isToday  = Model.SearchDate.Date == DateTime.Now.Date;

    var sectionColors = new Dictionary<string, string>
    {
        { "テストレジが稼働",   "#8b5cf6" },
        { "予約登録が稼働",     "#3b82f6" },
        { "製造中が稼働",       "#06b6d4" },
        { "デリバリーが稼働",   "#10b981" },
        { "運用中非稼働が稼働", "#22c55e" },
        { "退役未抹消が稼働",   "#f59e0b" },
        { "稼働が非稼働",       "#ef4444" },
        { "整備入り",           "#f97316" },
        { "整備終了",           "#84cc16" },
        { "整備中",             "#eab308" },
    };
}

@section CssPartial {
<style>
/* ===== WorkingCheckLog ===== */
.wcl-page { padding: 16px 0 60px; }

/* ヘッダー */
.wcl-header {
    display: flex; align-items: center; gap: 8px;
    flex-wrap: wrap; margin-bottom: 16px;
}
.wcl-header h2 {
    margin: 0; font-size: 1.3rem; font-weight: 700;
    color: #1e293b; flex: 1 1 auto;
}
.wcl-header h2 .date-label {
    font-size: 1rem; font-weight: 400; color: #64748b; margin-left: 6px;
}
.wcl-nav-btn {
    display: inline-flex; align-items: center;
    padding: 6px 14px; border-radius: 6px;
    border: 1px solid #cbd5e1; background: #fff;
    color: #334155; font-size: 0.88rem; font-weight: 600;
    text-decoration: none; white-space: nowrap; transition: background .15s;
}
.wcl-nav-btn:hover { background: #f1f5f9; text-decoration: none; color: #1e293b; }
.wcl-nav-btn.today { background: #0f172a; color: #fff; border-color: #0f172a; }
.wcl-nav-btn.today:hover { background: #1e293b; }

/* 統計チップ */
.wcl-stats { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 20px; }
.wcl-stat-chip {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 4px 12px 4px 10px; border-radius: 99px;
    font-size: 0.88rem; font-weight: 600; color: #fff;
}
.wcl-stat-chip .cnt {
    background: rgba(0,0,0,.22); border-radius: 99px;
    padding: 1px 8px; font-size: 0.82rem;
}

/* バッチカード */
.wcl-batch {
    border: 1px solid #e2e8f0; border-radius: 10px;
    margin-bottom: 28px; overflow: hidden;
    background: #fff; box-shadow: 0 1px 4px rgba(0,0,0,.06);
}
.wcl-batch-header {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 18px; background: #f8fafc;
    border-bottom: 1px solid #e2e8f0; flex-wrap: wrap;
}
.wcl-batch-title { font-size: 0.95rem; font-weight: 700; color: #475569; flex: 1 1 auto; }
.wcl-batch-time  { font-size: 0.88rem; color: #64748b; }
.wcl-batch-count { font-size: 0.85rem; color: #94a3b8; }

/* セクション */
.wcl-section { border-top: 2px solid #f1f5f9; }
.wcl-section:first-child { border-top: none; }
.wcl-section-header {
    display: flex; align-items: center; gap: 8px;
    padding: 11px 18px 9px; background: #fafbfc;
}
.wcl-section-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
.wcl-section-title { font-size: 0.95rem; font-weight: 700; color: #374151; }
.wcl-section-badge { margin-left: auto; font-size: 0.85rem; color: #94a3b8; white-space: nowrap; }

/* エントリ一覧 */
.wcl-entries { padding: 2px 10px 10px; }

.wcl-entry {
    display: grid;
    /* レジ | 型式 | 日時 | ルート＋便名＋状態 */
    grid-template-columns: 115px 140px 155px 1fr;
    gap: 0 14px;
    align-items: center;
    padding: 9px 8px;
    border-bottom: 1px solid #f1f5f9;
    font-size: 0.95rem;
    line-height: 1.4;
}
.wcl-entry:last-child { border-bottom: none; }
.wcl-entry:hover { background: #f8fafc; border-radius: 6px; }

/* レジ番号 */
.reg-link {
    font-weight: 700; font-size: 1.0rem;
    color: #1d4ed8; text-decoration: none; white-space: nowrap;
}
.reg-link:hover { text-decoration: underline; color: #1e40af; }
.reg-mark {
    display: inline-block; font-size: 0.68rem; font-weight: 700;
    padding: 1px 5px; border-radius: 4px; margin-left: 3px; vertical-align: middle;
}
.reg-mark.special { background: #fef3c7; color: #92400e; }
.reg-mark.mainte  { background: #ede9fe; color: #5b21b6; }

/* 型式 */
.type-name { font-size: 0.85rem; color: #64748b; }

/* 日時 */
.flight-date { font-size: 0.90rem; color: #334155; font-weight: 500; white-space: nowrap; }
.prev-date   { font-size: 0.78rem; color: #94a3b8; margin-top: 2px; }

/* ルート＋便名 */
.entry-route { display: flex; align-items: center; flex-wrap: wrap; gap: 4px 8px; }
.ap-pair     { display: flex; align-items: center; gap: 5px; }
.ap-code     { font-weight: 700; font-size: 0.95rem; color: #0f172a; }
.ap-name     { font-size: 0.80rem; color: #94a3b8; }
.route-arrow { color: #94a3b8; font-size: 0.80rem; }
.flight-num  { font-weight: 600; color: #0f766e; font-size: 0.90rem; white-space: nowrap; }
.flight-status { font-size: 0.85rem; color: #64748b; }

/* 生テキスト */
.raw-line { font-family: monospace; font-size: 0.85rem; color: #64748b; word-break: break-all; padding: 8px 4px; }

/* 空状態 */
.wcl-empty { text-align: center; padding: 60px 20px; color: #94a3b8; font-size: 1rem; }
.wcl-empty-icon { font-size: 2.5rem; margin-bottom: 10px; }

/* ========= レスポンシブ ========= */
/* タブレット縦 (〜900px) */
@@media (max-width: 900px) {
    .wcl-entry {
        grid-template-columns: 105px 115px 140px 1fr;
        font-size: 0.90rem; gap: 0 10px;
    }
    .type-name { font-size: 0.80rem; }
}

/* スマホ (〜600px): 2行レイアウト */
@@media (max-width: 600px) {
    .wcl-header h2 { font-size: 1.1rem; }
    .wcl-entries { padding: 2px 4px 8px; }
    .wcl-entry {
        grid-template-columns: 1fr 1fr;
        grid-template-rows: auto auto;
        gap: 3px 8px;
        padding: 10px 6px;
        font-size: 0.90rem;
    }
    /* 1行目: レジ | 型式 */
    .entry-reg   { grid-column: 1; grid-row: 1; }
    .entry-type  { grid-column: 2; grid-row: 1; text-align: right; }
    /* 2行目: 日時+ルート 全幅 */
    .entry-date  { grid-column: 1 / -1; grid-row: 2; }
    .entry-route-wrap { grid-column: 1 / -1; grid-row: 3; }
    .wcl-section-header { padding: 9px 12px 7px; }
    .wcl-batch-header   { padding: 8px 12px; }
    .ap-name { display: none; }
}
</style>
}

<div class="wcl-page">

    @* ヘッダーナビ *@
    <div class="wcl-header">
        <h2>✈ 稼働チェックログ<span class="date-label">@Model.SearchDate.ToString("yyyy年MM月dd日")</span></h2>
        <a href="/WorkingCheckLog/Index/@prevDate" class="wcl-nav-btn">← 前日</a>
        @if (!isToday)
        {
            <a href="/WorkingCheckLog/Index/@nextDate" class="wcl-nav-btn">翌日 →</a>
        }
        <a href="/WorkingCheckLog/Index" class="wcl-nav-btn today">今日</a>
    </div>

    @* 統計チップ *@
    @{
        var allSections = Model.Batches.SelectMany(b => b.Sections).ToList();
        var sectionGroups = allSections
            .GroupBy(s => s.SectionTitle ?? "")
            .Where(g => g.Any())
            .ToList();
    }
    @if (sectionGroups.Any())
    {
        <div class="wcl-stats">
            @foreach (var grp in sectionGroups)
            {
                var color = sectionColors.ContainsKey(grp.Key) ? sectionColors[grp.Key] : "#64748b";
                var totalCount = grp.Sum(s => s.Entries.Count);
                <span class="wcl-stat-chip" style="background:@color">
                    @grp.Key <span class="cnt">@totalCount</span>
                </span>
            }
        </div>
    }

    @* データなし *@
    @if (!Model.Batches.Any())
    {
        <div class="wcl-empty">
            <div class="wcl-empty-icon">📭</div>
            <div>@Model.SearchDate.ToString("yyyy/MM/dd") のログはありません</div>
        </div>
    }

    @* バッチ一覧 *@
    @for (int bi = 0; bi < Model.Batches.Count; bi++)
    {
        var batch = Model.Batches[bi];
        var totalInBatch = batch.AllEntries.Count();
        <div class="wcl-batch">
            <div class="wcl-batch-header">
                <span class="wcl-batch-title">バッチ #@(Model.Batches.Count - bi)</span>
                @if (!string.IsNullOrEmpty(batch.FinishedAt))
                {
                    <span class="wcl-batch-time">🕐 @batch.FinishedAt</span>
                }
                <span class="wcl-batch-count">@totalInBatch 件</span>
            </div>

            @if (!batch.Sections.Any())
            {
                <div style="padding:16px 20px;color:#94a3b8;font-size:0.95rem;">変化なし</div>
            }

            @foreach (var sec in batch.Sections)
            {
                var dotColor = sectionColors.ContainsKey(sec.SectionTitle ?? "") ? sectionColors[sec.SectionTitle!] : "#94a3b8";
                <div class="wcl-section">
                    <div class="wcl-section-header">
                        <span class="wcl-section-dot" style="background:@dotColor"></span>
                        <span class="wcl-section-title">@sec.SectionTitle</span>
                        <span class="wcl-section-badge">@sec.Entries.Count 件</span>
                    </div>
                    <div class="wcl-entries">
                        @foreach (var e in sec.Entries)
                        {
                            @if (e.RawLine != null)
                            {
                                <div class="raw-line">@e.RawLine</div>
                            }
                            else
                            {
                                <div class="wcl-entry">
                                    <div class="entry-reg">
                                        <a href="/AircraftDetail/Index/@e.RegistrationNumber" class="reg-link" target="_blank">@e.RegistrationNumber</a>
                                        @if (e.NotifyMark == "◎")
                                        {
                                            <span class="reg-mark special">特塗</span>
                                        }
                                        else if (e.NotifyMark == "☆")
                                        {
                                            <span class="reg-mark mainte">整備</span>
                                        }
                                    </div>
                                    <div class="entry-type type-name">@e.TypeName</div>
                                    <div class="entry-date">
                                        <div class="flight-date">@e.FlightDate</div>
                                        @if (!string.IsNullOrEmpty(e.PreviousDate))
                                        {
                                            <div class="prev-date">← 前回: @e.PreviousDate</div>
                                        }
                                    </div>
                                    <div class="entry-route-wrap">
                                        @if (!string.IsNullOrEmpty(e.FromAp))
                                        {
                                            <div class="entry-route">
                                                <div class="ap-pair">
                                                    <span class="ap-code">@e.FromApCode</span>
                                                    @if (!string.IsNullOrEmpty(e.FromApName))
                                                    {
                                                        <span class="ap-name">@e.FromApName</span>
                                                    }
                                                </div>
                                                <span class="route-arrow">▶</span>
                                                <div class="ap-pair">
                                                    <span class="ap-code">@e.ToApCode</span>
                                                    @if (!string.IsNullOrEmpty(e.ToApName))
                                                    {
                                                        <span class="ap-name">@e.ToApName</span>
                                                    }
                                                </div>
                                                @if (!string.IsNullOrEmpty(e.FlightNumber))
                                                {
                                                    <span class="flight-num">@e.FlightNumber</span>
                                                }
                                                @if (!string.IsNullOrEmpty(e.Status))
                                                {
                                                    <span class="flight-status">@e.Status</span>
                                                }
                                            </div>
                                        }
                                        else if (!string.IsNullOrEmpty(e.Status))
                                        {
                                            <span class="flight-status">@e.Status</span>
                                        }
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            }
        </div>
    }

</div>
